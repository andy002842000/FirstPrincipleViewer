# Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Gemini TEXT model (cheap + fast). e.g. gemini-3.1-flash-lite, gemini-2.5-flash
GEMINI_MODEL=gemini-3.1-flash-lite

# OCR languages for Tesseract.js (e.g. "eng", "eng+chi_tra", "eng+jpn").
# First run downloads the language data (cached afterwards).
OCR_LANGS=eng+chi_tra

# Continuous-monitor capture interval (milliseconds)
MONITOR_INTERVAL_MS=1500

# Language the explanation is written in
EXPLAIN_LANG=Traditional Chinese
